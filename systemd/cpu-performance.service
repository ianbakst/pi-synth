[Unit]
Description=Set CPU governor and IRQ affinity
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor && for irq in /proc/irq/[0-9]*/; do echo 3 > ${irq}smp_affinity 2>/dev/null; done'

[Install]
WantedBy=multi-user.target
