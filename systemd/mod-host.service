[Unit]
Description=mod-host LV2 Plugin Host
After=jack.service
Requires=jack.service

[Service]
Type=simple
User=synth
ExecStart=/usr/bin/chrt -f 80 /usr/bin/taskset -c 2,3 \
    /usr/bin/mod-host -n -p 5555
LimitRTPRIO=80
LimitMEMLOCK=infinity
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
